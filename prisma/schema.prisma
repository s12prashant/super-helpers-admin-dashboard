generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Employee {
  id         Int       @id @default(autoincrement())
  email      String?
  name       String?
  mobile     String?
  created_at DateTime?

  @@map("employee")
}

model ServicePackage {
  id                     Int       @id @default(autoincrement())
  package_name           String
  package_price          Decimal
  package_gst_percentage Decimal
  package_validity_days  Int?
  package_active         Boolean?
  package_created_at     DateTime?
  package_updated_at     DateTime?

  @@map("servicePackage")
}

model OrderGenerated {
  id                       Int       @id @default(autoincrement())
  order_id                 String    @unique
  employee_id              Int?
  order_package_id         Int?
  order_package_name       String?
  order_package_price      Decimal?
  order_package_gst        Decimal?
  order_package_created_at DateTime?
  coupon_used              String?
  refferal_point           Decimal?
  value_of_id              Decimal?

  @@map("orderGenerated")
}

model PaymentDetails {
  id                          Int       @id @default(autoincrement())
  payment_order_id            String    @unique
  employer_id                 Int?
  payment_status              String?
  original_payment_price      Decimal?
  package_id                  Int?
  payment_type                String?
  payment_gst                 Decimal?
  payment_total_ammount       Decimal?
  payment_ammount_without_gst Decimal?
  payment_ammount_with_offer  Decimal?
  offer_taken                 Decimal?
  payment_ammount             Decimal?
  is_replacement_activate     Boolean?
  contact_take                Decimal?
  payment_initated_date       DateTime?
  payment_expiry_date         DateTime?
  metadata                    Json?
  employer_mobile             String?
  rzp_payment_id              String?
  rzp_order_id                String?
  rzp_signature               String?
  rzp_status                  String?
  rzp_method                  String?
  created_at                  DateTime?
  updated_at                  DateTime?

  @@map("paymentDetails")
}
